@model ProntaComanda.Models.RelatorioVendas
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/styles/dashboard.css" />
}

<main class="admin-content">

    <header class="content-header dashboard-header">
        <div class="dashboard-header__title">
            <h1>Dashboard</h1>
            <p>Acompanhe o desempenho do seu restaurante em tempo real.</p>
        </div>
        <div class="dashboard-header__filters" role="group">
            <button class="period-btn period-btn--active" data-period="today">Hoje</button>
            <button class="period-btn" data-period="week">Esta semana</button>
            <button class="period-btn" data-period="month">Este mês</button>
        </div>
    </header>

    <!-- CARDS DE MÉTRICAS -->
    <section class="metrics-grid">

        <div class="metric-card metric-card--ganhos">
            <div class="metric-card__icon"><i class="fa-solid fa-sack-dollar"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Ganhos do Período</span>
                <strong class="metric-card__value" id="metric-ganhos">
                    R$ @Model?.GanhosTotais.ToString("N2")
                </strong>
            </div>
        </div>

        <div class="metric-card metric-card--pedidos">
            <div class="metric-card__icon"><i class="fa-solid fa-receipt"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Pedidos do Período</span>
                <strong class="metric-card__value" id="metric-pedidos">
                    @Model?.TotalPedidos
                </strong>
            </div>
        </div>

        <div class="metric-card metric-card--ticket">
            <div class="metric-card__icon"><i class="fa-solid fa-tags"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Ticket Médio</span>
                <strong class="metric-card__value" id="metric-ticket">
                    R$ @Model?.TicketMedio.ToString("N2")
                </strong>
            </div>
        </div>

        <div class="metric-card metric-card--mesas">
            <div class="metric-card__icon"><i class="fa-solid fa-ban"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Pedidos Cancelados</span>
                <strong class="metric-card__value" id="metric-cancelados">
                    @Model?.TotalCancelados
                </strong>
            </div>
        </div>

        <div class="metric-card metric-card--funcionarios">
            <div class="metric-card__icon"><i class="fa-solid fa-arrow-trend-up"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Taxa de Conversão</span>
                <strong class="metric-card__value" id="metric-conversao">
                    @Model?.TaxaConversao.ToString("N1")%
                </strong>
            </div>
        </div>

        <div class="metric-card metric-card--cardapio">
            <div class="metric-card__icon"><i class="fa-solid fa-utensils"></i></div>
            <div class="metric-card__body">
                <span class="metric-card__label">Top Produtos</span>
                <strong class="metric-card__value">
                    @(Model?.TopProdutos?.Count ?? 0) no ranking
                </strong>
            </div>
        </div>

    </section>

    <!-- GRÁFICOS -->
    <section class="charts-row">

        <div class="chart-card chart-card--bar">
            <header class="chart-card__header">
                <h2 class="chart-card__title">Faturamento por Mês</h2>
                <span class="chart-card__subtitle">Ano de @DateTime.Now.Year</span>
            </header>
            <div class="chart-card__body">
                <canvas id="chart-faturamento"></canvas>
            </div>
        </div>

        <div class="chart-card chart-card--donut">
            <header class="chart-card__header">
                <h2 class="chart-card__title">Taxa de Conversão de Pedidos</h2>
            </header>
            <div class="chart-card__body chart-card__body--split">
                <div class="donut-wrapper">
                    <canvas id="chart-conversao"></canvas>
                </div>
                <div class="cancelamentos">
                    <h3 class="cancelamentos__title">Status dos Pedidos</h3>
                    <table class="cancelamentos__table">
                        <thead>
                            <tr><th>Status</th><th>Qtd</th></tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Convertidos</td>
                                <td id="tbl-convertidos">@Model?.TotalPedidos</td>
                            </tr>
                            <tr>
                                <td>Cancelados</td>
                                <td id="tbl-cancelados">@Model?.TotalCancelados</td>
                            </tr>
                            <tr>
                                <td>Taxa</td>
                                <td id="tbl-taxa">@Model?.TaxaConversao.ToString("N1")%</td>
                            </tr>
                        </tbody>
                    </table>

                    @if (Model?.MotivosCancelamento != null && Model.MotivosCancelamento.Any())
                    {
                        <h3 class="cancelamentos__title" style="margin-top:1rem;">Motivos</h3>
                        <table class="cancelamentos__table">
                            <thead>
                                <tr><th>Motivo</th><th>Qtd</th><th>%</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var m in Model.MotivosCancelamento)
                                {
                                    <tr>
                                        <td>@m.Descricao</td>
                                        <td>@m.Quantidade</td>
                                        <td>@m.Percentual.ToString("N0")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

    </section>

    <!-- TOP PRODUTOS -->
    @if (Model?.TopProdutos != null && Model.TopProdutos.Any())
    {
        <section class="top-produtos">
            <header class="top-produtos__header">
                <h2 class="top-produtos__title">Top Produtos do Período</h2>
                <span class="top-produtos__subtitle">Ordenado por faturamento</span>
            </header>
            <div class="top-produtos__table-wrapper">
                <table class="top-produtos__table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Produto</th>
                            <th>Categoria</th>
                            <th>QTD Vendida</th>
                            <th>Faturado</th>
                            <th>Participação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var p in Model.TopProdutos)
                        {
                            <tr>
                                <td class="rank @(rank == 1 ? "rank--gold" : rank == 2 ? "rank--silver" : rank == 3 ? "rank--bronze" : "")">
                                    @rank
                                </td>
                                <td class="produto-nome">@p.NomeProduto</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.CategoriaNome))
                                    {
                                        <span class="categoria-badge">@p.CategoriaNome</span>
                                    }
                                </td>
                                <td>@p.QuantidadeVendida</td>
                                <td class="faturado">R$ @p.TotalFaturado.ToString("N2")</td>
                                <td>
                                    <div class="progress-bar-wrapper">
                                        <div class="progress-bar" style="width: @p.ParticipacaoPercentual.ToString("N0")%"></div>
                                    </div>
                                    @p.ParticipacaoPercentual.ToString("N0")%
                                </td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }

</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js"></script>
}
