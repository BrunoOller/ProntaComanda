<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - ProntaComanda</title>

    <link rel="stylesheet" href="~/css/global/reset.css" />
    <link rel="stylesheet" href="~/css/global/color.css" />
    <link rel="stylesheet" href="~/css/styles/layout.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="shortcut icon" href="~/img/prontaComanda.png" type="image/x-icon" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="admin-page">

        <!-- ===== SIDEBAR ESQUERDA ===== -->
        <aside class="admin-sidebar" aria-label="Navegação principal">
            <div class="sidebar-logo">
                <i class="fa-solid fa-cubes-stacked" aria-hidden="true"></i>
                <span class="logo-text">ProntaComanda</span>
            </div>
            <nav class="sidebar-nav" aria-label="Menu administrativo">
                <a asp-controller="Produtos" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Produtos" ? "active" : "")"
                       title="Cardápio">
                    <i class="fa-solid fa-utensils" aria-hidden="true"></i>
                    <span class="menu-text">Cardápio</span>
                </a>
                <a asp-controller="Mesas" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Mesas" ? "active" : "")"
                       title="Mesas">
                    <i class="fa-solid fa-bell-concierge" aria-hidden="true"></i>
                    <span class="menu-text">Mesas</span>
                </a>
                <a asp-controller="Pedidos" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Pedidos" ? "active" : "")"
                       title="KDS">
                    <i class="fa-solid fa-fire" aria-hidden="true"></i>
                    <span class="menu-text">KDS</span>
                </a>
                <a asp-controller="Relatorios" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Relatorios" ? "active" : "")"
                       title="Dashboard">
                    <i class="fa-solid fa-chart-line" aria-hidden="true"></i>
                    <span class="menu-text">Dashboard</span>
                </a>
                <a asp-controller="Funcionarios" asp-action="Index"
                       class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Funcionarios" ? "active" : "")"
                       title="Funcionários">
                    <i class="fa-solid fa-user" aria-hidden="true"></i>
                    <span class="menu-text">Funcionários</span>
                </a>
            </nav>
        </aside>

        <!-- ===== CONTEÚDO DA PÁGINA ===== -->
        <main class="admin-content">
            @RenderBody()
        </main>

    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>